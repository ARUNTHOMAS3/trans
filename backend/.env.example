# ZERPAI ERP - Backend Environment Variables
# Copy this file to .env and update with your actual values

# Server Configuration
PORT=3001
NODE_ENV=development

# Supabase Configuration
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:3001,https://zerpai-erp-one.vercel.app,https://zerpai--erp.web.app

# Database Configuration
DATABASE_URL=your_database_connection_string_here

# Security Settings
JWT_SECRET=your_jwt_secret_here
SESSION_SECRET=your_session_secret_here

# External API Keys (Optional)
SANDBOX_API_KEY=your_sandbox_api_key_here
SANDBOX_API_SECRET=your_sandbox_api_secret_here
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_TEST_TO_EMAIL=zabnixprivatelimited@gmail.com
AUTH_RESET_REDIRECT_URL=http://localhost:3000/login

# Logging Configuration
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true
ENABLE_HELMET=true
ENABLE_BULL_BOARD=true
SENTRY_DSN=your_sentry_dsn_here

# Performance Settings
REQUEST_TIMEOUT=30000
MAX_REQUEST_SIZE=10mb

# Upstash Redis (Optional / Test & Queue Infrastructure)
UPSTASH_REDIS_URL=rediss://default:your_upstash_redis_token@your-upstash-host.upstash.io:6379
UPSTASH_REDIS_REST_URL=https://your-upstash-host.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token_here
