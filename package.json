{
  "scripts": {
    "test:flutter": "flutter test",
    "test:backend": "npm test --prefix backend -- --runInBand",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:all": "npm run test:flutter && npm run test:backend && npm run test:e2e"
  },
  "dependencies": {
    "@microsoft/clarity": "^1.0.2",
    "agentation": "^1.3.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.1",
    "@types/node": "^20.11.24",
    "http-server": "^14.1.1"
  }
}
